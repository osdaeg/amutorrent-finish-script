# --- Configuración ---
HOST="192.168.88.100"
BASEDIR=/scripts
GOTIFY_TOKEN="TuTokenDeGotify"
GOTIFY_URL="${HOST}:8088/message"
CLAMAV_URL="${HOST}:3311/api/v1/scan"
TRANSFERR_URL="${HOST}:7900/transfer"
BUTLER_URL="${HOST}:7999/process"
PASTEBIN_URL="${HOST}:8090"
LOG_FILE="${BASEDIR}/finished.log"

# --- Ejecutables con ruta completa (requerido en Alpine) ---
JQ="/usr/bin/jq"
CURL="/usr/bin/curl"
DATE="/bin/date"

# --- Extensiones ---
VIDEO_EXTENSIONS="mkv mp4 avi mov wmv m4v ts m2ts webm divx xvid mpg mpeg vob rmvb 3gp"
BOOK_EXTENSIONS="epub pdf mobi azw3 azw djvu fb2 lit lrf"
COMIC_EXTENSIONS="cbz cbr cb7 cbt pdf"
MUSIC_EXTENSIONS="mp3 flac ogg m4a wav aac opus wma ape alac"

# --- Comportamiento ---
NOTIFICATIONS="yes"
TRANSFER="yes"
SCAN="yes"
PASTEBIN="yes"
CARDS="yes"
SUBTITLES="yes"

# --- Proveedores de subtitulos ---
OPENSUBS_API_KEY="TuAPIKeyDeOpenSubtitles"
OPENSUBS_USER="user"
OPENSUBS_PASS="pass"
OPENSUBS_URL="https://api.opensubtitles.com/api/v1"
OPENSUBS_USERAGENT="finish.sh v1.0"
SUBDL_API_KEY="TuAPIKeyDeSubDL"
SUBDL_URL="https://api.subdl.com/api/v1"
SUBDL_DL_URL="https://dl.subdl.com"